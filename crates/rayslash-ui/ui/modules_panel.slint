import { ModuleItem } from "./models.slint";

component ModuleTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> light;
    callback clicked();

    height: 34px;
    border-radius: 7px;
    background: root.selected
        ? root.light ? #202020 : #d6d6d6
        : tab-touch.has-hover ? root.light ? #eeeeee : #292929 : transparent;

    animate background { duration: 90ms; }

    Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: root.selected
            ? root.light ? #ffffff : #181818
            : root.light ? #333333 : #dddddd;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    tab-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component ModuleSwitch inherits Rectangle {
    in property <bool> checked;
    in property <bool> available;
    in property <bool> light;
    callback toggled(bool);

    width: 38px;
    height: 22px;
    border-radius: 11px;
    opacity: root.available ? 1 : 0.45;
    background: root.light
        ? root.checked ? #202020 : #dedede
        : root.checked ? #d6d6d6 : #343434;
    border-width: 1px;
    border-color: root.light ? #999999 : #666666;

    Rectangle {
        x: root.checked ? 18px : 2px;
        y: 2px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: root.light
            ? root.checked ? #ffffff : #777777
            : root.checked ? #181818 : #b8b8b8;

        animate x { duration: 100ms; }
    }

    switch-touch := TouchArea {
        enabled: root.available;
        mouse-cursor: root.available ? pointer : default;
        clicked => {
            root.toggled(!root.checked);
        }
    }
}

component ModuleIcon inherits Rectangle {
    in property <string> kind;
    in property <string> text;
    in property <bool> light;

    width: 38px;
    height: 38px;
    border-radius: 9px;
    background: root.light ? #e8e8e8 : #343434;
    private property <color> glyph: root.light ? #4d4d4d : #d0d0d0;

    Text {
        width: 100%; height: 100%; text: root.text; color: root.glyph;
        font-size: 16px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center;
        visible: root.text != "";
    }
    Rectangle { x: 9px; y: 6px; width: 20px; height: 26px; border-radius: 3px; background: transparent; border-width: 2px; border-color: root.glyph; visible: root.kind == "calculator"; }
    Rectangle { x: 14px; y: 12px; width: 10px; height: 2px; background: root.glyph; visible: root.kind == "calculator"; }
    Rectangle { x: 8px; y: 8px; width: 22px; height: 22px; border-radius: 11px; background: transparent; border-width: 2px; border-color: root.glyph; visible: root.kind == "time" || root.kind == "stopwatch"; }
    Rectangle { x: 18px; y: 12px; width: 2px; height: 9px; border-radius: 1px; background: root.glyph; visible: root.kind == "time" || root.kind == "stopwatch"; }
    Rectangle { x: 18px; y: 19px; width: 7px; height: 2px; border-radius: 1px; background: root.glyph; visible: root.kind == "time" || root.kind == "stopwatch"; }
    if root.kind == "stopwatch": Path { x: 12px; y: 4px; width: 14px; height: 8px; viewbox-width: 14; viewbox-height: 8; commands: "M3 6 L7 2 L11 6"; stroke: root.glyph; stroke-width: 2px; fill: transparent; }
    if root.kind == "search": Path { x: 8px; y: 7px; width: 22px; height: 22px; viewbox-width: 24; viewbox-height: 24; commands: "M10.5 4 A6.5 6.5 0 1 0 10.5 17 A6.5 6.5 0 1 0 10.5 4 M15.5 15.5 L21 21"; stroke: root.glyph; stroke-width: 2px; fill: transparent; }
    if root.kind == "link": Path { x: 7px; y: 7px; width: 24px; height: 24px; viewbox-width: 24; viewbox-height: 24; commands: "M10 13a5 5 0 0 0 7.1.1l3-3a5 5 0 0 0-7.1-7.1l-1.7 1.7 M14 11a5 5 0 0 0-7.1-.1l-3 3a5 5 0 0 0 7.1 7.1l1.7-1.7"; stroke: root.glyph; stroke-width: 2px; fill: transparent; }
}

component ModuleCard inherits Rectangle {
    in property <ModuleItem> item;
    in property <bool> shown;
    in property <bool> light;
    callback toggle-requested(string, bool);
    callback action-requested(string, string);

    private property <bool> has-feedback: root.item.operation_summary != "";
    private property <length> feedback-height: !root.has-feedback ? 0px
        : root.item.operation_details_expanded ? 94px : 38px;
    height: root.shown ? 136px + root.feedback-height : 0px;
    visible: root.shown;
    border-radius: 10px;
    background: root.light ? #ffffff : #202020;
    border-width: 1px;
    border-color: root.light ? #d0d0d0 : #3a3a3a;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 11px;

        ModuleIcon {
            vertical-stretch: 0;
            kind: root.item.icon_kind;
            text: root.item.icon_text;
            light: root.light;
        }

        VerticalLayout {
            spacing: 3px;

            HorizontalLayout {
                height: 21px;
                spacing: 7px;

                Text {
                    text: root.item.name;
                    color: root.light ? #1f1f1f : #f2f2f2;
                    font-size: 14px;
                    font-weight: 700;
                    overflow: elide;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: root.item.official ? 52px : 0px;
                    height: 18px;
                    visible: root.item.official;
                    border-radius: 5px;
                    background: root.light ? #e2e2e2 : #393939;
                    horizontal-stretch: 0;

                    Text {
                        width: 100%;
                        height: 100%;
                        text: "Official";
                        color: root.light ? #454545 : #cfcfcf;
                        font-size: 9px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Text {
                height: 18px;
                text: root.item.description;
                color: root.light ? #555555 : #b8b8b8;
                font-size: 11px;
                overflow: elide;
                vertical-alignment: center;
            }

            Text {
                height: 16px;
                text: root.item.permissions;
                color: root.light ? #6d5a38 : #c5aa78;
                font-size: 9px;
                overflow: elide;
                vertical-alignment: center;
            }

            HorizontalLayout {
                height: 18px;
                spacing: 6px;

                Text {
                    text: "by " + root.item.author;
                    color: root.light ? #707070 : #929292;
                    font-size: 10px;
                    overflow: elide;
                    vertical-alignment: center;
                }

                Text {
                    text: root.item.version == "" ? "" : "v" + root.item.version;
                    color: root.light ? #777777 : #888888;
                    font-size: 10px;
                    horizontal-stretch: 0;
                    vertical-alignment: center;
                }

                Text {
                    text: root.item.stars == "" ? "" : "★ " + root.item.stars;
                    color: root.light ? #777777 : #888888;
                    font-size: 10px;
                    horizontal-stretch: 0;
                    vertical-alignment: center;
                }

                Text {
                    text: root.item.license == "" ? "" : root.item.license + " · " + root.item.review_status;
                    color: root.light ? #777777 : #888888;
                    font-size: 9px;
                    horizontal-stretch: 0;
                    vertical-alignment: center;
                }
            }

            Text {
                height: 18px;
                text: root.item.operation_pending ? root.item.operation_label : root.item.status;
                color: root.item.operation_failed
                    ? root.light ? #9b3030 : #f29a9a
                    : root.item.operation_pending ? root.light ? #765b18 : #e4c46b
                    : root.item.installed && root.item.enabled
                    ? root.light ? #2f6a43 : #86c99d
                    : root.light ? #777777 : #969696;
                font-size: 10px;
                font-weight: 600;
                vertical-alignment: center;
            }

            if root.has-feedback: Rectangle {
                height: root.feedback-height;
                border-radius: 6px;
                background: root.item.operation_failed
                    ? root.light ? #fff0f0 : #3b2424
                    : root.light ? #eef5ef : #243329;

                VerticalLayout {
                    padding-left: 7px; padding-right: 7px; padding-top: 4px; padding-bottom: 4px;
                    spacing: 2px;
                    Text {
                        text: root.item.operation_summary;
                        color: root.item.operation_failed
                            ? root.light ? #852828 : #f0aaaa
                            : root.light ? #315f3d : #9bcba7;
                        font-size: 9px; font-weight: 600;
                        wrap: word-wrap;
                    }
                    if root.item.operation_details_expanded: Text {
                        text: root.item.operation_details;
                        color: root.light ? #555555 : #c0c0c0;
                        font-size: 9px;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                    if root.item.operation_details != root.item.operation_summary: Text {
                        text: root.item.operation_details_expanded ? "Hide details" : "Show details";
                        color: details-touch.has-hover
                            ? root.light ? #111111 : #ffffff
                            : root.light ? #555555 : #bcbcbc;
                        font-size: 8px;
                        details-touch := TouchArea {
                            enabled: !root.item.operation_pending;
                            mouse-cursor: pointer;
                            clicked => { root.action-requested(root.item.id, "Details"); }
                        }
                    }
                }
            }
        }

        VerticalLayout {
            width: 62px;
            spacing: 5px;
            alignment: center;

            Rectangle {
                height: 22px;
                background: transparent;

                ModuleSwitch {
                    x: (parent.width - self.width) / 2;
                    checked: root.item.enabled;
                    available: root.item.installed && !root.item.operation_pending;
                    light: root.light;
                    toggled(enabled) => {
                        root.toggle-requested(root.item.id, enabled);
                    }
                }
            }

            Text {
                text: root.item.enabled ? "Enabled" : "Disabled";
                color: root.light ? #666666 : #9a9a9a;
                font-size: 9px;
                horizontal-alignment: center;
            }

            Rectangle {
                height: 24px;
                border-radius: 6px;
                background: action-touch.has-hover
                    ? root.light ? #d6d6d6 : #444444
                    : root.light ? #e7e7e7 : #343434;
                border-width: 1px;
                border-color: root.light ? #bdbdbd : #555555;

                Text {
                    width: 100%; height: 100%;
                    text: root.item.operation_pending ? root.item.operation_label : root.item.action;
                    color: root.light ? #333333 : #dddddd;
                    font-size: 9px; font-weight: 700;
                    horizontal-alignment: center; vertical-alignment: center;
                }
                action-touch := TouchArea {
                    enabled: !root.item.operation_pending;
                    mouse-cursor: root.item.operation_pending ? default : pointer;
                    clicked => { root.action-requested(root.item.id, root.item.action); }
                }
            }

            Text {
                height: root.item.installed ? 14px : 0px;
                visible: root.item.installed;
                text: "Remove + data";
                color: remove-all-touch.has-hover
                    ? root.light ? #8a2f2f : #ef9a9a
                    : root.light ? #777777 : #999999;
                font-size: 8px;
                horizontal-alignment: center;
                vertical-alignment: center;
                remove-all-touch := TouchArea {
                    enabled: !root.item.operation_pending;
                    mouse-cursor: root.item.operation_pending ? default : pointer;
                    clicked => { root.action-requested(root.item.id, "Remove all"); }
                }
            }

            Text {
                height: root.item.repository == "" ? 0px : 14px;
                visible: root.item.repository != "";
                text: "Source";
                color: source-touch.has-hover
                    ? root.light ? #222222 : #eeeeee
                    : root.light ? #666666 : #aaaaaa;
                font-size: 9px;
                horizontal-alignment: center;
                vertical-alignment: center;
                source-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.action-requested(root.item.id, "Source"); }
                }
            }
        }
    }
}

export component ModulesPanel inherits FocusScope {
    in property <[ModuleItem]> modules;
    in property <bool> light;
    callback module-toggle-requested(string, bool);
    callback module-action-requested(string, string);

    private property <string> selected-tab: "installed";

    public function reset-scroll() {
        module-scroll.viewport-y = 0px;
    }

    VerticalLayout {
        spacing: 8px;

        Text {
            height: 18px;
            text: "Manage bundled capabilities without changing the launcher core.";
            color: root.light ? #666666 : #9a9a9a;
            font-size: 11px;
            vertical-alignment: center;
        }

        Rectangle {
            height: 38px;
            border-radius: 9px;
            background: root.light ? #e7e7e7 : #222222;
            border-width: 1px;
            border-color: root.light ? #d0d0d0 : #3a3a3a;

            HorizontalLayout {
                padding: 2px;
                spacing: 2px;

                ModuleTab {
                    label: "Installed";
                    selected: root.selected-tab == "installed";
                    light: root.light;
                    clicked => {
                        root.selected-tab = "installed";
                        root.reset-scroll();
                    }
                }

                ModuleTab {
                    label: "Official";
                    selected: root.selected-tab == "official";
                    light: root.light;
                    clicked => {
                        root.selected-tab = "official";
                        root.reset-scroll();
                    }
                }

                ModuleTab {
                    label: "Community";
                    selected: root.selected-tab == "community";
                    light: root.light;
                    clicked => {
                        root.selected-tab = "community";
                        root.reset-scroll();
                    }
                }
            }
        }

        module-scroll := Flickable {
            min-height: 0px;
            vertical-stretch: 1;
            viewport-width: self.width;
            viewport-height: root.modules.length * 246px + 72px;
            interactive: true;

            VerticalLayout {
                width: module-scroll.width;
                spacing: 8px;

                for item in root.modules: ModuleCard {
                    item: item;
                    shown: root.selected-tab == "installed"
                        ? item.installed
                        : root.selected-tab == "official" ? item.official : !item.official;
                    light: root.light;
                    toggle-requested(id, enabled) => {
                        root.module-toggle-requested(id, enabled);
                    }
                    action-requested(id, action) => {
                        root.module-action-requested(id, action);
                    }
                }

                Rectangle {
                    height: 64px;
                    border-radius: 10px;
                    background: root.light ? #eeeeee : #202020;
                    border-width: 1px;
                    border-color: root.light ? #d4d4d4 : #3a3a3a;

                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 9px;
                        padding-bottom: 9px;
                        spacing: 3px;

                        Text {
                            text: "Community modules";
                            color: root.light ? #333333 : #d8d8d8;
                            font-size: 11px;
                            font-weight: 700;
                        }

                        Text {
                            text: "Community modules are loaded from the verified registry.";
                            color: root.light ? #707070 : #929292;
                            font-size: 10px;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }
}

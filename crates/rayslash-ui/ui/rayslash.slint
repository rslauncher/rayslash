import { SearchBox, SettingsGearIcon } from "./components.slint";
import { AppChoiceItem, ResultItem } from "./models.slint";
import { ResultList } from "./result_list.slint";
import { SettingsPanel } from "./settings_panel.slint";

export { AppChoiceItem, ResultItem }from "./models.slint";

component HeaderBar inherits HorizontalLayout {
    in property <bool> settings-open;
    callback settings-requested();

    height: 36px;
    alignment: space-between;

    HorizontalLayout {
        spacing: 8px;

        Rectangle {
            width: 32px;
            height: 100%;
            background: transparent;

            Image {
                x: 0px;
                y: (parent.height - self.height) / 2 + 2px;
                width: 28px;
                height: 28px;
                source: @image-url("../../../icons/rayslash-icon.svg");
                image-fit: contain;
            }
        }

        Text {
            text: "rayslash";
            color: #f5f5f5;
            font-size: 22px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    Rectangle {
        width: 34px;
        height: 34px;
        background: transparent;
        opacity: settings-button-touch.pressed ? 1 : settings-button-touch.has-hover || root.settings-open ? 1 : 0.72;

        animate opacity { duration: 90ms; }

        SettingsGearIcon {
            width: 34px;
            height: 34px;
        }

        settings-button-touch := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                root.settings-requested();
            }
        }
    }
}

component HintKey inherits Text {
    color: #dedede;
    font-size: 11px;
    font-weight: 700;
    horizontal-stretch: 0;
    vertical-alignment: center;
}

component HintText inherits Text {
    color: #9a9a9a;
    font-size: 11px;
    horizontal-stretch: 0;
    vertical-alignment: center;
}

component LauncherHint inherits Rectangle {
    in property <string> status-text;
    in property <bool> alternate-folder-opener-enabled;

    height: 16px;
    background: transparent;

    if root.status-text != "": Text {
        height: 16px;
        text: root.status-text;
        color: #b8b8b8;
        font-size: 11px;
        overflow: elide;
        vertical-alignment: center;
    }

    if root.status-text == "": HorizontalLayout {
        height: 16px;
        spacing: 4px;

        HintKey {
            text: "Enter";
        }

        HintText {
            text: ": launch/open/show result";
        }

        if root.alternate-folder-opener-enabled: HintKey {
            text: "  Ctrl+Enter";
        }
        if root.alternate-folder-opener-enabled: HintText {
            text: ": alt-open folders";
        }

        HintKey {
            text: "  Esc";
        }

        HintText {
            text: ": hide";
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }
    }
}

export component AppWindow inherits Window {
    in property <[ResultItem]> results;
    in property <[AppChoiceItem]> alternate-opener-choices;
    in property <int> result-count;
    in-out property <int> selected-index: -1;
    in-out property <string> query-text: "";
    in-out property <string> status-text: "";
    in-out property <bool> settings-open: false;
    in-out property <string> settings-folder-sources: "";
    in-out property <string> settings-alternate-folder-opener-command: "xdg-terminal-exec";
    in-out property <bool> settings-provider-apps: true;
    in-out property <bool> settings-provider-folders: true;
    in-out property <bool> settings-provider-calculator: true;
    in-out property <bool> settings-provider-aliases: true;
    in-out property <bool> settings-alternate-folder-opener-enabled: true;
    in-out property <bool> settings-ranking-learn-from-usage: true;
    in-out property <string> settings-theme: "dark";
    in-out property <string> settings-density: "comfortable";
    in-out property <string> settings-max-results: "50";
    in-out property <string> settings-config-path: "";
    in-out property <string> settings-state-path: "";
    in-out property <string> settings-socket-path: "";
    in-out property <string> settings-project-count: "0";
    in-out property <string> settings-app-count: "0";
    in-out property <string> settings-icon-count: "0";
    in-out property <string> settings-ranking-entry-count: "0";
    in-out property <bool> alternate-folder-opener-enabled: true;
    in property <image> alternate-folder-opener-icon;
    in property <bool> alternate-folder-opener-has-icon: false;
    in property <color> alternate-folder-opener-background: #3a3a3a;
    in property <string> alternate-folder-opener-label: "TM";
    in-out property <bool> control-held: false;
    in-out property <bool> settings-alternate-picker-open: false;

    callback close-requested();
    callback query-changed(string);
    callback activate-selected-result(int, bool);
    callback reset-requested();
    callback settings-requested();
    callback settings-cancel-requested();
    callback settings-browse-folder-requested(string);
    callback settings-choose-alternate-opener-requested(string);
    callback settings-clear-ranking-requested();
    callback settings-save-requested(string, string, bool, bool, bool, bool, bool, bool, string, string, string);

    public function focus-search() {
        search.focus();
    }

    public function focus-settings() {
        settings-panel.focus-settings();
    }

    public function reset-result-scroll() {
        results-list.reset-scroll();
    }

    function keep-selection-visible() {
        results-list.keep-selection-visible();
    }

    function select-previous() {
        if (root.selected-index > -1) {
            root.selected-index = root.selected-index - 1;
            root.keep-selection-visible();
        }
    }

    function select-next() {
        if (root.selected-index < root.result-count - 1) {
            root.selected-index = root.selected-index + 1;
            root.keep-selection-visible();
        }
    }

    function activate-selected(use-alternate-opener: bool) {
        if (root.result-count > 0 && root.selected-index >= 0) {
            root.activate-selected-result(root.selected-index, use-alternate-opener);
        }
    }

    title: "rayslash";
    icon: @image-url("../../../icons/rayslash-icon.svg");
    preferred-width: 660px;
    preferred-height: 440px;
    min-width: 520px;
    min-height: 400px;
    no-frame: true;
    resize-border-width: 0px;
    background: transparent;

    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;

        FocusScope {
            width: 100%;
            height: 100%;
            forward-focus: search;

            key-pressed(event) => {
                root.control-held = event.modifiers.control;
                if (event.text == Key.Escape) {
                    if (root.settings-open) {
                        root.settings-cancel-requested();
                    } else {
                        root.close-requested();
                    }
                    accept
                } else if (event.text == Key.Tab && event.modifiers.shift) {
                    root.select-previous();
                    accept
                } else if (event.text == Key.Tab) {
                    root.select-next();
                    accept
                } else if (event.text == Key.UpArrow) {
                    root.select-previous();
                    accept
                } else if (event.text == Key.DownArrow) {
                    root.select-next();
                    accept
                } else if (event.text == Key.Return && event.modifiers.control) {
                    root.activate-selected(true);
                    accept
                } else if (event.text == Key.Return) {
                    root.activate-selected(false);
                    accept
                } else {
                    reject
                }
            }

            key-released(event) => {
                root.control-held = event.text == Key.Control || event.text == Key.ControlR ? false : event.modifiers.control;
                reject
            }

            Rectangle {
                x: 0px;
                y: 0px;
                width: 100%;
                height: 100%;
                border-radius: 14px;
                background: root.settings-theme == "dim" ? #202020 : #181818;
                border-width: 1px;
                border-color: #343434;
                clip: true;

                VerticalLayout {
                    padding-left: 22px;
                    padding-right: 22px;
                    padding-top: 20px;
                    padding-bottom: 8px;
                    spacing: 0px;

                    HeaderBar {
                        settings-open: root.settings-open;
                        settings-requested => {
                            root.settings-requested();
                        }
                    }

                    Rectangle {
                        height: root.settings-open ? 8px : 12px;
                        background: transparent;
                    }

                    search := SearchBox {
                        height: root.settings-open ? 0px : 62px;
                        visible: !root.settings-open;
                        query-text <=> root.query-text;

                        close-requested => {
                            root.close-requested();
                        }
                        select-previous => {
                            root.select-previous();
                        }
                        select-next => {
                            root.select-next();
                        }
                        activate-selected(use-alternate-opener) => {
                            root.activate-selected(use-alternate-opener);
                        }
                        query-changed(query) => {
                            root.query-changed(query);
                        }
                        control-modifier-changed(control) => {
                            root.control-held = control;
                        }
                    }

                    Rectangle {
                        height: root.settings-open ? 0px : 12px;
                        background: transparent;
                    }

                    LauncherHint {
                        height: root.settings-open ? 0px : 16px;
                        visible: !root.settings-open;
                        status-text: root.status-text;
                        alternate-folder-opener-enabled: root.alternate-folder-opener-enabled;
                    }

                    Rectangle {
                        height: root.settings-open ? 0px : 10px;
                        background: transparent;
                    }

                    settings-panel := SettingsPanel {
                        open <=> root.settings-open;
                        alternate-opener-choices: root.alternate-opener-choices;
                        folder-sources <=> root.settings-folder-sources;
                        alternate-folder-opener-command <=> root.settings-alternate-folder-opener-command;
                        provider-apps <=> root.settings-provider-apps;
                        provider-folders <=> root.settings-provider-folders;
                        provider-calculator <=> root.settings-provider-calculator;
                        provider-aliases <=> root.settings-provider-aliases;
                        alternate-folder-opener-enabled <=> root.settings-alternate-folder-opener-enabled;
                        ranking-learn-from-usage <=> root.settings-ranking-learn-from-usage;
                        theme <=> root.settings-theme;
                        density <=> root.settings-density;
                        max-results <=> root.settings-max-results;
                        config-path: root.settings-config-path;
                        state-path: root.settings-state-path;
                        socket-path: root.settings-socket-path;
                        project-count: root.settings-project-count;
                        app-count: root.settings-app-count;
                        icon-count: root.settings-icon-count;
                        ranking-entry-count: root.settings-ranking-entry-count;
                        alternate-picker-open <=> root.settings-alternate-picker-open;

                        cancel-requested => {
                            root.settings-cancel-requested();
                        }
                        browse-folder-requested(path) => {
                            root.settings-browse-folder-requested(path);
                        }
                        choose-alternate-opener-requested(command) => {
                            root.settings-choose-alternate-opener-requested(command);
                        }
                        clear-ranking-requested => {
                            root.settings-clear-ranking-requested();
                        }
                        save-requested(folder-sources, alternate-opener-command, provider-apps, provider-folders, provider-calculator, provider-aliases, alternate-opener-enabled, ranking-learn-from-usage, theme, density, max-results) => {
                            root.settings-save-requested(
                                folder-sources,
                                alternate-opener-command,
                                provider-apps,
                                provider-folders,
                                provider-calculator,
                                provider-aliases,
                                alternate-opener-enabled,
                                ranking-learn-from-usage,
                                theme,
                                density,
                                max-results);
                        }
                    }

                    results-list := ResultList {
                        min-height: 0px;
                        preferred-height: root.settings-open ? 0px : 240px;
                        visible: !root.settings-open;
                        vertical-stretch: root.settings-open ? 0 : 1;
                        interactive: !root.settings-open;
                        results: root.results;
                        result-count: root.result-count;
                        selected-index <=> root.selected-index;
                        control-held: root.control-held;
                        alternate-folder-opener-icon: root.alternate-folder-opener-icon;
                        alternate-folder-opener-has-icon: root.alternate-folder-opener-has-icon;
                        alternate-folder-opener-background: root.alternate-folder-opener-background;
                        alternate-folder-opener-label: root.alternate-folder-opener-label;
                        density: root.settings-density;

                        activate-result(index, use-alternate-opener) => {
                            root.activate-selected-result(index, use-alternate-opener);
                        }
                    }
                }
            }
        }
    }
}

export struct ResultItem {
    title: string,
    subtitle: string,
}

component SearchBox inherits Rectangle {
    callback close-requested();
    callback select-previous();
    callback select-next();
    callback activate-selected();
    in property <bool> dark-theme;

    height: 62px;
    border-radius: 8px;
    background: dark-theme ? (search-input.has-focus ? #111827 : #1f2937) : (search-input.has-focus ? #ffffff : #f8fafc);
    border-width: 2px;
    border-color: search-input.has-focus ? #2563eb : (dark-theme ? #475569 : #cbd5e1);

    forward-focus: search-input;

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    Text {
        x: 18px;
        y: 0px;
        height: parent.height;
        vertical-alignment: center;
        text: "Search apps, projects, or calculations";
        color: dark-theme ? #94a3b8 : #64748b;
        font-size: 18px;
        visible: search-input.text == "";
    }

    search-input := TextInput {
        x: 18px;
        y: 0px;
        width: parent.width - 36px;
        height: parent.height;
        vertical-alignment: center;
        color: dark-theme ? #f8fafc : #0f172a;
        font-size: 19px;
        font-weight: 500;
        single-line: true;
        selection-background-color: #2563eb;
        selection-foreground-color: #ffffff;

        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.close-requested();
                accept
            } else if (event.text == Key.UpArrow) {
                root.select-previous();
                accept
            } else if (event.text == Key.DownArrow) {
                root.select-next();
                accept
            } else if (event.text == Key.Return) {
                root.activate-selected();
                accept
            } else {
                reject
            }
        }
    }
}

export component AppWindow inherits Window {
    in property <[ResultItem]> results;
    in property <int> result-count;
    in property <bool> dark-theme: true;
    in-out property <int> selected-index: 0;
    in-out property <string> status-text: "Use Up/Down to select. Enter previews only.";
    callback close-requested();
    callback activate-placeholder(int);

    public function focus-search() {
        search.focus();
    }

    function select-previous() {
        if (root.selected-index > 0) {
            root.selected-index = root.selected-index - 1;
        }
    }

    function select-next() {
        if (root.selected-index < root.result-count - 1) {
            root.selected-index = root.selected-index + 1;
        }
    }

    function activate-selected() {
        if (root.result-count > 0) {
            root.activate-placeholder(root.selected-index);
        }
    }

    title: "rayslash";
    preferred-width: 660px;
    preferred-height: 362px;
    min-width: 520px;
    min-height: 320px;
    no-frame: true;
    resize-border-width: 0px;
    background: dark-theme ? #020617 : #e2e8f0;

    Rectangle {
        width: 100%;
        height: 100%;
        background: root.background;

        FocusScope {
            width: 100%;
            height: 100%;
            forward-focus: search;

            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.close-requested();
                    accept
                } else if (event.text == Key.UpArrow) {
                    root.select-previous();
                    accept
                } else if (event.text == Key.DownArrow) {
                    root.select-next();
                    accept
                } else if (event.text == Key.Return) {
                    root.activate-selected();
                    accept
                } else {
                    reject
                }
            }

            Rectangle {
                x: 0px;
                y: 0px;
                width: 100%;
                height: 100%;
                border-radius: 10px;
                background: root.dark-theme ? #0f172a : #ffffff;
                border-width: 1px;
                border-color: root.dark-theme ? #334155 : #cbd5e1;

                VerticalLayout {
                    padding-left: 22px;
                    padding-right: 22px;
                    padding-top: 20px;
                    padding-bottom: 18px;
                    spacing: 12px;

                    HorizontalLayout {
                        height: 28px;
                        alignment: space-between;

                        Text {
                            text: "rayslash";
                            color: root.dark-theme ? #f8fafc : #0f172a;
                            font-size: 22px;
                            font-weight: 700;
                        }

                        Text {
                            text: "preview";
                            color: root.dark-theme ? #38bdf8 : #2563eb;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    search := SearchBox {
                        dark-theme: root.dark-theme;
                        close-requested => {
                            root.close-requested();
                        }
                        select-previous => {
                            root.select-previous();
                        }
                        select-next => {
                            root.select-next();
                        }
                        activate-selected => {
                            root.activate-selected();
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: root.dark-theme ? #334155 : #e2e8f0;
                    }

                    VerticalLayout {
                        spacing: 8px;

                        for item[i] in root.results: Rectangle {
                            height: 64px;
                            border-radius: 8px;
                            background: i == root.selected-index ? (root.dark-theme ? #1d4ed8 : #dbeafe) : (root.dark-theme ? #111827 : #f8fafc);
                            border-width: 1px;
                            border-color: i == root.selected-index ? (root.dark-theme ? #60a5fa : #93c5fd) : (root.dark-theme ? #253245 : #e2e8f0);

                            animate background { duration: 90ms; }
                            animate border-color { duration: 90ms; }

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 8px;
                                padding-bottom: 8px;
                                spacing: 12px;

                                Rectangle {
                                    width: 34px;
                                    height: 34px;
                                    border-radius: 6px;
                                    background: i == root.selected-index ? (root.dark-theme ? #bfdbfe : #2563eb) : (root.dark-theme ? #334155 : #e2e8f0);
                                    vertical-stretch: 0;
                                }

                                VerticalLayout {
                                    spacing: 2px;

                                    Text {
                                        text: item.title;
                                        color: i == root.selected-index ? (root.dark-theme ? #ffffff : #0f172a) : (root.dark-theme ? #e2e8f0 : #0f172a);
                                        font-size: 16px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        text: item.subtitle;
                                        color: i == root.selected-index ? (root.dark-theme ? #dbeafe : #1e40af) : (root.dark-theme ? #94a3b8 : #475569);
                                        font-size: 13px;
                                    }
                                }
                            }
                        }
                    }

                    Text {
                        text: root.status-text;
                        color: root.dark-theme ? #94a3b8 : #64748b;
                        font-size: 12px;
                        height: 18px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

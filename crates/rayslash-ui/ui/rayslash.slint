export struct ResultItem {
    title: string,
    subtitle: string,
}

component SearchBox inherits Rectangle {
    in-out property <string> query-text;

    callback close-requested();
    callback select-previous();
    callback select-next();
    callback activate-selected(bool);
    callback query-changed(string);

    height: 62px;
    border-radius: 12px;
    background: search-input.has-focus ? #242424 : #202020;
    border-width: 1.5px;
    border-color: search-input.has-focus ? #7a7a7a : #3a3a3a;

    forward-focus: search-input;

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    Text {
        x: 18px;
        y: 0px;
        height: parent.height;
        vertical-alignment: center;
        text: "Search apps, projects, or calculations";
        color: #9a9a9a;
        font-size: 18px;
        visible: search-input.text == "";
    }

    search-input := TextInput {
        x: 18px;
        y: 0px;
        width: parent.width - 36px;
        height: parent.height;
        vertical-alignment: center;
        color: #f2f2f2;
        font-size: 19px;
        font-weight: 500;
        single-line: true;
        selection-background-color: #d4d4d4;
        selection-foreground-color: #181818;
        text <=> root.query-text;

        edited => {
            root.query-changed(search-input.text);
        }

        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.close-requested();
                accept
            } else if (event.text == Key.Tab && event.modifiers.shift) {
                root.select-previous();
                accept
            } else if (event.text == Key.Tab) {
                root.select-next();
                accept
            } else if (event.text == Key.UpArrow) {
                root.select-previous();
                accept
            } else if (event.text == Key.DownArrow) {
                root.select-next();
                accept
            } else if (event.text == Key.Return && event.modifiers.control) {
                root.activate-selected(true);
                accept
            } else if (event.text == Key.Return) {
                root.activate-selected(false);
                accept
            } else {
                reject
            }
        }
    }
}

export component AppWindow inherits Window {
    in property <[ResultItem]> results;
    in property <int> result-count;
    in-out property <int> selected-index: 0;
    in-out property <string> query-text: "";
    in-out property <string> status-text: "Type to filter apps and projects. Enter launches. Ctrl+Enter opens projects in VS Code.";
    callback close-requested();
    callback query-changed(string);
    callback activate-selected-result(int, bool);
    callback reset-requested();

    public function focus-search() {
        search.focus();
    }

    function select-previous() {
        if (root.selected-index > 0) {
            root.selected-index = root.selected-index - 1;
        }
    }

    function select-next() {
        if (root.selected-index < root.result-count - 1) {
            root.selected-index = root.selected-index + 1;
        }
    }

    function activate-selected(open-in-vscode: bool) {
        if (root.result-count > 0) {
            root.activate-selected-result(root.selected-index, open-in-vscode);
        }
    }

    title: "rayslash";
    preferred-width: 660px;
    preferred-height: 380px;
    min-width: 520px;
    min-height: 360px;
    no-frame: true;
    resize-border-width: 0px;
    background: transparent;

    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;

        FocusScope {
            width: 100%;
            height: 100%;
            forward-focus: search;

            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.close-requested();
                    accept
                } else if (event.text == Key.Tab && event.modifiers.shift) {
                    root.select-previous();
                    accept
                } else if (event.text == Key.Tab) {
                    root.select-next();
                    accept
                } else if (event.text == Key.UpArrow) {
                    root.select-previous();
                    accept
                } else if (event.text == Key.DownArrow) {
                    root.select-next();
                    accept
                } else if (event.text == Key.Return && event.modifiers.control) {
                    root.activate-selected(true);
                    accept
                } else if (event.text == Key.Return) {
                    root.activate-selected(false);
                    accept
                } else {
                    reject
                }
            }

            Rectangle {
                x: 0px;
                y: 0px;
                width: 100%;
                height: 100%;
                border-radius: 14px;
                background: #181818;
                border-width: 1px;
                border-color: #343434;
                clip: true;

                VerticalLayout {
                    padding-left: 22px;
                    padding-right: 22px;
                    padding-top: 20px;
                    padding-bottom: 20px;
                    spacing: 12px;

                    HorizontalLayout {
                        height: 28px;
                        alignment: space-between;

                        Text {
                            text: "rayslash";
                            color: #f5f5f5;
                            font-size: 22px;
                            font-weight: 700;
                        }

                        Text {
                            text: "preview";
                            color: #b8b8b8;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    search := SearchBox {
                        query-text <=> root.query-text;

                        close-requested => {
                            root.close-requested();
                        }
                        select-previous => {
                            root.select-previous();
                        }
                        select-next => {
                            root.select-next();
                        }
                        activate-selected(open-in-vscode) => {
                            root.activate-selected(open-in-vscode);
                        }
                        query-changed(query) => {
                            root.query-changed(query);
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: #303030;
                    }

                    VerticalLayout {
                        spacing: 8px;

                        for item[i] in root.results: Rectangle {
                            height: 64px;
                            border-radius: 12px;
                            background: i == root.selected-index ? #343434 : #222222;
                            border-width: 1px;
                            border-color: i == root.selected-index ? #6a6a6a : #303030;

                            animate background { duration: 90ms; }
                            animate border-color { duration: 90ms; }

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 8px;
                                padding-bottom: 8px;
                                spacing: 12px;

                                Rectangle {
                                    width: 38px;
                                    height: 100%;
                                    background: #00000000;

                                    Rectangle {
                                        x: 0px;
                                        y: (parent.height - self.height) / 2;
                                        width: 36px;
                                        height: 36px;
                                        border-radius: 10px;
                                        background: i == root.selected-index ? #d6d6d6 : #3a3a3a;
                                    }
                                }

                                VerticalLayout {
                                    spacing: 2px;

                                    Text {
                                        text: item.title;
                                        color: #f4f4f4;
                                        font-size: 16px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        text: item.subtitle;
                                        color: i == root.selected-index ? #d0d0d0 : #a0a0a0;
                                        font-size: 13px;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 4px;
                        background: transparent;
                    }

                    Text {
                        text: root.status-text;
                        color: #9a9a9a;
                        font-size: 12px;
                        height: 18px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

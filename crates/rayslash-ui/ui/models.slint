export struct ResultItem {
    title: string,
    flair: string,
    subtitle: string,
    subtitle_tooltip: string,
    icon: image,
    has_icon: bool,
    icon_kind: string,
    icon_text: string,
}

export struct AppChoiceItem {
    name: string,
    command: string,
    icon: image,
    has_icon: bool,
}

export struct AliasItem {
    name: string,
    keyword: string,
    kind: string,
    target: string,
}

export struct WebSearchItem {
    name: string,
    keyword: string,
    url: string,
    enabled: bool,
    icon: image,
    has_icon: bool,
}

export struct ModuleItem {
    id: string,
    name: string,
    description: string,
    author: string,
    version: string,
    enabled: bool,
    installed: bool,
    official: bool,
    stars: string,
    action: string,
    action_available: bool,
    secondary_action: string,
    secondary_action_available: bool,
    update_available: bool,
    has_saved_data: bool,
    category: string,
    installed_count: int,
    restorable_count: int,
    official_count: int,
    community_count: int,
    permissions: string,
    repository: string,
    license: string,
    review_status: string,
    status: string,
    operation_pending: bool,
    operation_label: string,
    operation_summary: string,
    operation_details: string,
    operation_failed: bool,
    operation_confirmation: bool,
    operation_details_expanded: bool,
    icon_kind: string,
    icon_text: string,
}

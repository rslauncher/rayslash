export struct ResultItem {
    title: string,
    flair: string,
    subtitle: string,
    subtitle_tooltip: string,
    icon: image,
    has_icon: bool,
    icon_kind: string,
    icon_text: string,
}

export struct AppChoiceItem {
    name: string,
    command: string,
    icon: image,
    has_icon: bool,
}

export struct AliasItem {
    name: string,
    keyword: string,
    kind: string,
    target: string,
}

export struct WebSearchItem {
    name: string,
    keyword: string,
    url: string,
    enabled: bool,
    icon: image,
    has_icon: bool,
    valid: bool,
}

export struct ModuleItem {
    id: string,
    name: string,
    description: string,
    author: string,
    version: string,
    enabled: bool,
    installed: bool,
    official: bool,
    stars: string,
    action: string,
    update_available: bool,
    icon_kind: string,
    icon_text: string,
}

import { ResultItem } from "./models.slint";
import { LegendTooltipBubble } from "./components.slint";

export component ResultList inherits Flickable {
    in property <[ResultItem]> results;
    in property <int> result-count;
    in-out property <int> selected-index;
    in property <bool> control-held;
    in property <image> alternate-folder-opener-icon;
    in property <bool> alternate-folder-opener-has-icon;
    in property <color> alternate-folder-opener-background;
    in property <string> alternate-folder-opener-label;
    in property <string> density: "comfortable";
    in property <bool> light;
    in property <string> result-tip-text;
    in property <bool> tooltips-enabled;
    callback activate-result(int, bool);

    private property <length> row-height: root.density == "compact" ? 54px : 64px;
    private property <length> row-gap: root.density == "compact" ? 6px : 8px;
    private property <length> row-stride: root.row-height + root.row-gap;
    private property <length> tip-height: root.result-tip-text == "" ? 0px : 18px;
    private property <length> tip-gap: root.result-tip-text == "" || root.result-count <= 0 ? 0px : root.row-gap;
    private property <bool> click-open-in-alternate-opener: false;
    private property <string> tooltip-text: "";
    private property <length> tooltip-x: 0px;
    private property <length> tooltip-y: 0px;
    private property <bool> tooltip-visible: false;
    private property <length> tooltip-max-width: max(0px, root.width - root.tooltip-x - 6px);
    private property <length> tooltip-width: root.tooltip-text == "" ? 0px : min(tooltip-measure.preferred-width + 18px, root.tooltip-max-width);
    private property <length> tooltip-height: root.tooltip-text == "" ? 0px : min(max(30px, tooltip-wrapped-measure.preferred-height + 12px), 54px);
    private property <bool> pointer-over-list: false;
    private property <length> pointer-y: 0px;
    private property <int> hovered-index: -1;
    private property <int> pressed-index: -1;

    public function reset-scroll() {
        root.viewport-y = 0px;
        root.hide-tooltip();
    }

    public function keep-selection-visible() {
        if (root.result-count <= 0 || root.selected-index < 0) {
            root.reset-scroll();
            return;
        }

        let selected-top = root.selected-index * root.row-stride;
        let selected-bottom = selected-top + root.row-height;
        let visible-top = -root.viewport-y;
        let visible-bottom = visible-top + root.height;

        if (selected-top < visible-top) {
            root.viewport-y = -selected-top;
        } else if (selected-bottom > visible-bottom) {
            root.viewport-y = -(selected-bottom - root.height);
        }
    }

    function show-tooltip(text: string, x: length, y: length) {
        tooltip-delay.running = false;
        root.tooltip-visible = false;
        root.tooltip-text = text;
        root.tooltip-x = x;
        root.tooltip-y = y;
        if (root.tooltips-enabled && text != "") {
            tooltip-delay.running = true;
        }
    }

    function hide-tooltip() {
        tooltip-delay.running = false;
        root.tooltip-visible = false;
        root.tooltip-text = "";
    }

    function row-index-at(pointer-y: length) -> int {
        if root.result-count <= 0 {
            return -1;
        }

        let content-y = pointer-y - root.viewport-y;
        if content-y < 0px {
            return -1;
        }

        let index = floor(content-y / root.row-stride);
        if index < 0 || index >= root.result-count {
            return -1;
        }

        let row-y = index * root.row-stride;
        if content-y > row-y + root.row-height {
            return -1;
        }

        return index;
    }

    function update-hovered-row(pointer-y: length, control: bool) {
        let index = root.row-index-at(pointer-y);
        root.hovered-index = index;

        if index >= 0 {
            root.selected-index = index;
            root.click-open-in-alternate-opener = control;
            root.show-tooltip(
                root.results[index].subtitle_tooltip,
                76px,
                max(0px, min(index * root.row-stride + root.row-height + root.viewport-y + 6px, root.height - 34px)),
            );
        } else {
            root.hide-tooltip();
        }
    }

    viewport-width: self.width;
    viewport-height: root.result-count <= 0 ? root.tip-height : root.result-count * root.row-stride - root.row-gap + root.tip-gap + root.tip-height;

    tooltip-delay := Timer {
        interval: 800ms;
        running: false;

        triggered => {
            self.running = false;
            if root.tooltip-text != "" {
                root.tooltip-visible = true;
            }
        }
    }

    tooltip-measure := Text {
        width: 0px;
        height: 0px;
        text: root.tooltip-text;
        font-size: 11px;
        font-weight: 600;
        visible: false;
    }

    tooltip-wrapped-measure := Text {
        width: max(0px, root.tooltip-width - 18px);
        height: 0px;
        text: root.tooltip-text;
        font-size: 11px;
        font-weight: 600;
        wrap: word-wrap;
        visible: false;
    }

    changed viewport-y => {
        if (root.pointer-over-list) {
            root.update-hovered-row(root.pointer-y, root.control-held);
        } else {
            root.hide-tooltip();
        }
    }

    changed tooltips-enabled => {
        if (!root.tooltips-enabled) {
            root.hide-tooltip();
        }
    }

    for item[i] in root.results: Rectangle {
        y: i * root.row-stride;
        width: root.width;
        height: root.row-height;
        border-radius: 12px;
        background: root.light ? i == root.pressed-index ? #d8d8d8 : i == root.selected-index ? #dedede : i == root.hovered-index ? #e8e8e8 : #ffffff : i == root.pressed-index ? #3c3c3c : i == root.selected-index ? #343434 : i == root.hovered-index ? #2a2a2a : #222222;
        border-width: 1px;
        border-color: root.light ? i == root.selected-index ? #9c9c9c : i == root.hovered-index ? #c4c4c4 : #d7d7d7 : i == root.selected-index ? #6a6a6a : i == root.hovered-index ? #474747 : #303030;

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 8px;
            padding-bottom: 8px;
            spacing: 12px;

            Rectangle {
                width: 50px;
                height: 100%;
                background: #00000000;

                Image {
                    x: 5px;
                    y: (parent.height - self.height) / 2;
                    width: 40px;
                    height: 40px;
                    source: item.icon;
                    image-fit: contain;
                    visible: item.has_icon;
                }

                Rectangle {
                    x: 4px;
                    y: (parent.height - self.height) / 2;
                    width: 42px;
                    height: 42px;
                    border-radius: 10px;
                    property <bool> alternate-icon: root.control-held && item.icon_kind == "folder";
                    background: self.alternate-icon ? root.alternate-folder-opener-background : root.light ? i == root.selected-index ? #202020 : #e0e0e0 : i == root.selected-index ? #d6d6d6 : #3a3a3a;
                    visible: !item.has_icon;

                    Text {
                        x: 0px;
                        y: 0px;
                        width: 100%;
                        height: 100%;
                        text: item.icon_text;
                        color: root.light ? i == root.selected-index ? #ffffff : #4d4d4d : i == root.selected-index ? #242424 : #d0d0d0;
                        font-size: 19px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        visible: !parent.alternate-icon && !item.has_icon && item.icon_text != "";
                    }

                    Image {
                        x: 7px;
                        y: 7px;
                        width: 28px;
                        height: 28px;
                        source: root.alternate-folder-opener-icon;
                        image-fit: contain;
                        visible: parent.alternate-icon && root.alternate-folder-opener-has-icon;
                    }

                    Text {
                        x: 0px;
                        y: 0px;
                        width: 100%;
                        height: 100%;
                        text: root.alternate-folder-opener-label;
                        color: #ffffff;
                        font-size: 13px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        visible: parent.alternate-icon && !root.alternate-folder-opener-has-icon;
                    }

                    Rectangle {
                        x: 7px;
                        y: 14px;
                        width: 28px;
                        height: 19px;
                        border-radius: 3px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "folder";
                        opacity: parent.alternate-icon ? 0 : 1;
                    }

                    Rectangle {
                        x: 8px;
                        y: 10px;
                        width: 14px;
                        height: 8px;
                        border-radius: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "folder";
                        opacity: parent.alternate-icon ? 0 : 1;
                    }

                    Rectangle {
                        x: 11px;
                        y: 8px;
                        width: 20px;
                        height: 26px;
                        border-radius: 3px;
                        background: transparent;
                        border-width: 2px;
                        border-color: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "calculator";
                    }

                    Rectangle {
                        x: 16px;
                        y: 14px;
                        width: 10px;
                        height: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "calculator";
                    }

                    Rectangle {
                        x: 11px;
                        y: 11px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 23px;
                        y: 11px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 11px;
                        y: 23px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 23px;
                        y: 23px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 16px;
                        y: 16px;
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "placeholder";
                    }

                    Rectangle {
                        x: 10px;
                        y: 10px;
                        width: 22px;
                        height: 22px;
                        border-radius: 11px;
                        background: transparent;
                        border-width: 2px;
                        border-color: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "time";
                    }

                    Rectangle {
                        x: 20px;
                        y: 14px;
                        width: 2px;
                        height: 9px;
                        border-radius: 1px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "time";
                    }

                    Rectangle {
                        x: 20px;
                        y: 21px;
                        width: 7px;
                        height: 2px;
                        border-radius: 1px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "time";
                    }

                    Rectangle {
                        x: 10px;
                        y: 11px;
                        width: 22px;
                        height: 22px;
                        border-radius: 11px;
                        background: transparent;
                        border-width: 2px;
                        border-color: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "power";
                    }

                    Rectangle {
                        x: 20px;
                        y: 7px;
                        width: 3px;
                        height: 15px;
                        border-radius: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "power";
                    }

                    Path {
                        x: 7px;
                        y: 7px;
                        width: 28px;
                        height: 28px;
                        viewbox-width: 24;
                        viewbox-height: 24;
                        commands: "M17 5 A8 8 0 1 0 20 12 M20 12 L20 5 M20 12 L13 12";
                        stroke: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        stroke-width: 2.2px;
                        fill: transparent;
                        visible: !item.has_icon && item.icon_kind == "reboot";
                    }

                    Rectangle {
                        x: 10px;
                        y: 9px;
                        width: 13px;
                        height: 24px;
                        border-radius: 2px;
                        background: transparent;
                        border-width: 2px;
                        border-color: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "logout";
                    }

                    Path {
                        x: 9px;
                        y: 8px;
                        width: 28px;
                        height: 28px;
                        viewbox-width: 24;
                        viewbox-height: 24;
                        commands: "M10 12 H21 M17 8 L21 12 L17 16";
                        stroke: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        stroke-width: 2.4px;
                        fill: transparent;
                        visible: !item.has_icon && item.icon_kind == "logout";
                    }

                    Rectangle {
                        x: 12px;
                        y: 12px;
                        width: 18px;
                        height: 18px;
                        border-radius: 9px;
                        background: transparent;
                        border-width: 2px;
                        border-color: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "stopwatch";
                    }

                    Rectangle {
                        x: 18px;
                        y: 7px;
                        width: 7px;
                        height: 4px;
                        border-radius: 2px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "stopwatch";
                    }

                    Rectangle {
                        x: 20px;
                        y: 17px;
                        width: 2px;
                        height: 7px;
                        border-radius: 1px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "stopwatch";
                    }

                    Rectangle {
                        x: 21px;
                        y: 22px;
                        width: 6px;
                        height: 2px;
                        border-radius: 1px;
                        background: root.light ? i == root.selected-index ? #ffffff : #555555 : i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "stopwatch";
                    }
                }
            }

            VerticalLayout {
                spacing: 2px;

                Rectangle {
                    height: 22px;
                    horizontal-stretch: 1;
                    background: transparent;

                    title-measure := Text {
                        width: 0px;
                        height: 0px;
                        text: item.title;
                        font-size: 16px;
                        font-weight: 700;
                        visible: false;
                    }

                    title-text := Text {
                        x: 0px;
                        width: item.flair == "" ? parent.width : max(0px, parent.width - 42px);
                        height: 100%;
                        text: item.title;
                        color: root.light ? #202020 : #f4f4f4;
                        font-size: 16px;
                        font-weight: 700;
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        x: item.flair == "" ? 0px : min(title-measure.preferred-width + 8px, max(0px, parent.width - 34px));
                        y: 2px;
                        width: item.flair == "" ? 0px : 34px;
                        height: item.flair == "" ? 0px : 18px;
                        border-radius: 6px;
                        background: root.light ? #202020 : #d6d6d6;
                        visible: item.flair != "";
                        horizontal-stretch: 0;

                        Text {
                            width: 100%;
                            height: 100%;
                            text: item.flair;
                            color: root.light ? #ffffff : #181818;
                            font-size: 10px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                Text {
                    horizontal-stretch: 1;
                    text: item.subtitle;
                    color: root.light ? i == root.selected-index ? #3f3f3f : #656565 : i == root.selected-index ? #d0d0d0 : #a0a0a0;
                    font-size: 13px;
                    overflow: elide;
                }
            }
        }

    }

    Rectangle {
        x: 0px;
        y: root.result-count <= 0 ? 0px : root.result-count * root.row-stride - root.row-gap + root.tip-gap;
        width: root.width;
        height: root.tip-height;
        visible: root.result-tip-text != "";
        background: transparent;

        Text {
            height: 100%;
            text: root.result-tip-text;
            color: root.light ? #555555 : #b8b8b8;
            font-size: 11px;
            overflow: elide;
            vertical-alignment: center;
        }
    }

    list-touch := TouchArea {
        x: 0px;
        y: -root.viewport-y;
        width: root.width;
        height: root.height;
        mouse-cursor: pointer;

        clicked => {
            let index = root.row-index-at(self.mouse-y);
            if index >= 0 {
                root.selected-index = index;
                root.activate-result(index, root.click-open-in-alternate-opener);
            }
        }

        pointer-event(event) => {
            if event.kind == PointerEventKind.down || event.kind == PointerEventKind.move || event.kind == PointerEventKind.up {
                root.pointer-over-list = true;
                root.pointer-y = self.mouse-y;
                root.update-hovered-row(self.mouse-y, event.modifiers.control);
            }

            if event.kind == PointerEventKind.down {
                root.pressed-index = root.row-index-at(self.mouse-y);
            } else if event.kind == PointerEventKind.up {
                root.pressed-index = -1;
            }
        }

        changed has-hover => {
            root.pointer-over-list = self.has-hover;
            if (self.has-hover) {
                root.pointer-y = self.mouse-y;
                root.update-hovered-row(self.mouse-y, root.control-held);
            } else {
                root.hovered-index = -1;
                root.pressed-index = -1;
                root.hide-tooltip();
            }
        }
    }

    LegendTooltipBubble {
        x: root.tooltip-x;
        y: root.tooltip-y - root.viewport-y;
        width: root.tooltip-width;
        height: root.tooltip-visible && root.tooltip-text != "" ? root.tooltip-height : 0px;
        visible: root.tooltip-visible && root.tooltip-text != "";
        text: root.tooltip-text;
        light: root.light;
    }
}

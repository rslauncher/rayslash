import { ResultItem } from "./models.slint";

export component ResultList inherits Flickable {
    in property <[ResultItem]> results;
    in property <int> result-count;
    in-out property <int> selected-index;
    in property <bool> control-held;
    in property <image> alternate-folder-opener-icon;
    in property <bool> alternate-folder-opener-has-icon;
    in property <color> alternate-folder-opener-background;
    in property <string> alternate-folder-opener-label;
    callback activate-result(int, bool);

    private property <length> row-height: 64px;
    private property <length> row-gap: 8px;
    private property <length> row-stride: root.row-height + root.row-gap;
    private property <bool> click-open-in-alternate-opener: false;

    public function reset-scroll() {
        root.viewport-y = 0px;
    }

    public function keep-selection-visible() {
        if (root.result-count <= 0 || root.selected-index < 0) {
            root.reset-scroll();
            return;
        }

        let selected-top = root.selected-index * root.row-stride;
        let selected-bottom = selected-top + root.row-height;
        let visible-top = -root.viewport-y;
        let visible-bottom = visible-top + root.height;

        if (selected-top < visible-top) {
            root.viewport-y = -selected-top;
        } else if (selected-bottom > visible-bottom) {
            root.viewport-y = -(selected-bottom - root.height);
        }
    }

    viewport-width: self.width;
    viewport-height: root.result-count <= 0 ? 0px : root.result-count * root.row-stride - root.row-gap;

    for item[i] in root.results: Rectangle {
        y: i * root.row-stride;
        width: root.width;
        height: root.row-height;
        border-radius: 12px;
        background: row-touch.pressed ? #3c3c3c : i == root.selected-index ? #343434 : row-touch.has-hover ? #2a2a2a : #222222;
        border-width: 1px;
        border-color: i == root.selected-index ? #6a6a6a : row-touch.has-hover ? #474747 : #303030;

        animate background { duration: 90ms; }
        animate border-color { duration: 90ms; }

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 8px;
            padding-bottom: 8px;
            spacing: 12px;

            Rectangle {
                width: 50px;
                height: 100%;
                background: #00000000;

                Image {
                    x: 4px;
                    y: (parent.height - self.height) / 2;
                    width: 42px;
                    height: 42px;
                    source: item.icon;
                    image-fit: contain;
                    visible: item.has_icon;
                }

                Rectangle {
                    x: 4px;
                    y: (parent.height - self.height) / 2;
                    width: 42px;
                    height: 42px;
                    border-radius: 10px;
                    property <bool> alternate-icon: root.control-held && item.icon_kind == "folder";
                    background: self.alternate-icon ? root.alternate-folder-opener-background : i == root.selected-index ? #d6d6d6 : #3a3a3a;
                    visible: !item.has_icon;

                    animate background { duration: 120ms; easing: ease; }

                    Text {
                        x: 0px;
                        y: 0px;
                        width: 100%;
                        height: 100%;
                        text: item.icon_text;
                        color: i == root.selected-index ? #242424 : #d0d0d0;
                        font-size: 19px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        visible: !parent.alternate-icon && !item.has_icon && item.icon_text != "";
                    }

                    Image {
                        x: 7px;
                        y: 7px;
                        width: 28px;
                        height: 28px;
                        source: root.alternate-folder-opener-icon;
                        image-fit: contain;
                        visible: parent.alternate-icon && root.alternate-folder-opener-has-icon;
                    }

                    Text {
                        x: 0px;
                        y: 0px;
                        width: 100%;
                        height: 100%;
                        text: root.alternate-folder-opener-label;
                        color: #ffffff;
                        font-size: 13px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        visible: parent.alternate-icon && !root.alternate-folder-opener-has-icon;
                    }

                    Rectangle {
                        x: 7px;
                        y: 14px;
                        width: 28px;
                        height: 19px;
                        border-radius: 3px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "folder";
                        opacity: parent.alternate-icon ? 0 : 1;
                        animate opacity { duration: 120ms; easing: ease; }
                    }

                    Rectangle {
                        x: 8px;
                        y: 10px;
                        width: 14px;
                        height: 8px;
                        border-radius: 2px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "folder";
                        opacity: parent.alternate-icon ? 0 : 1;
                        animate opacity { duration: 120ms; easing: ease; }
                    }

                    Rectangle {
                        x: 11px;
                        y: 8px;
                        width: 20px;
                        height: 26px;
                        border-radius: 3px;
                        background: transparent;
                        border-width: 2px;
                        border-color: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "calculator";
                    }

                    Rectangle {
                        x: 16px;
                        y: 14px;
                        width: 10px;
                        height: 2px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "calculator";
                    }

                    Rectangle {
                        x: 11px;
                        y: 11px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 23px;
                        y: 11px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 11px;
                        y: 23px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 23px;
                        y: 23px;
                        width: 8px;
                        height: 8px;
                        border-radius: 2px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "app";
                    }

                    Rectangle {
                        x: 16px;
                        y: 16px;
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: i == root.selected-index ? #303030 : #d0d0d0;
                        visible: !item.has_icon && item.icon_kind == "placeholder";
                    }
                }
            }

            VerticalLayout {
                spacing: 2px;

                Text {
                    text: item.title;
                    color: #f4f4f4;
                    font-size: 16px;
                    font-weight: 700;
                }

                Text {
                    text: item.subtitle;
                    color: i == root.selected-index ? #d0d0d0 : #a0a0a0;
                    font-size: 13px;
                }
            }
        }

        row-touch := TouchArea {
            mouse-cursor: pointer;

            clicked => {
                root.selected-index = i;
                root.activate-result(i, root.click-open-in-alternate-opener);
            }

            pointer-event(event) => {
                if (event.kind == PointerEventKind.down || event.kind == PointerEventKind.up) {
                    root.click-open-in-alternate-opener = event.modifiers.control;
                    root.selected-index = i;
                } else if (event.kind == PointerEventKind.move) {
                    root.selected-index = i;
                }
            }

            changed has-hover => {
                if (self.has-hover) {
                    root.selected-index = i;
                }
            }
        }
    }
}

export component SearchBox inherits Rectangle {
    in-out property <string> query-text;
    in property <bool> light;

    callback close-requested();
    callback select-previous();
    callback select-next();
    callback activate-selected(bool);
    callback query-changed(string);
    callback control-modifier-changed(bool);

    height: 62px;
    border-radius: 12px;
    background: root.light ? search-input.has-focus ? #ffffff : #f7f7f7 : search-input.has-focus ? #242424 : #202020;
    border-width: 1.5px;
    border-color: root.light ? search-input.has-focus ? #767676 : #c9c9c9 : search-input.has-focus ? #7a7a7a : #3a3a3a;

    forward-focus: search-input;

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    Text {
        x: 18px;
        y: 0px;
        height: parent.height;
        vertical-alignment: center;
        text: "Search apps, folders, or calculations";
        color: root.light ? #6b6b6b : #9a9a9a;
        font-size: 18px;
        visible: search-input.text == "";
    }

    search-input := TextInput {
        x: 18px;
        y: 0px;
        width: parent.width - 36px;
        height: parent.height;
        vertical-alignment: center;
        color: root.light ? #1f1f1f : #f2f2f2;
        font-size: 19px;
        font-weight: 500;
        single-line: true;
        selection-background-color: root.light ? #2f2f2f : #d4d4d4;
        selection-foreground-color: root.light ? #ffffff : #181818;
        text <=> root.query-text;

        edited => {
            root.query-changed(search-input.text);
        }

        key-pressed(event) => {
            root.control-modifier-changed(event.modifiers.control);
            if (event.text == Key.Escape) {
                root.close-requested();
                accept
            } else if (event.text == Key.Tab && event.modifiers.shift) {
                root.select-previous();
                accept
            } else if (event.text == Key.Tab) {
                root.select-next();
                accept
            } else if (event.text == Key.UpArrow) {
                root.select-previous();
                accept
            } else if (event.text == Key.DownArrow) {
                root.select-next();
                accept
            } else if (event.text == Key.Return && event.modifiers.control) {
                root.activate-selected(true);
                accept
            } else if (event.text == Key.Return) {
                root.activate-selected(false);
                accept
            } else {
                reject
            }
        }

        key-released(event) => {
            root.control-modifier-changed(
                event.text == Key.Control || event.text == Key.ControlR ? false : event.modifiers.control
            );
            reject
        }
    }
}

export component SettingsGearIcon inherits Rectangle {
    in property <color> icon-color: #d8d8d8;

    background: transparent;

    Path {
        x: 5px;
        y: 5px;
        width: 24px;
        height: 24px;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: "M9.6 3.1h4.8l.5 2.5c.5.2 1 .4 1.4.8l2.4-.9 2.4 4.1-1.9 1.6v1.6l1.9 1.6-2.4 4.1-2.4-.9c-.4.3-.9.6-1.4.8l-.5 2.5H9.6l-.5-2.5c-.5-.2-1-.4-1.4-.8l-2.4.9-2.4-4.1 1.9-1.6v-1.6L2.9 9.6l2.4-4.1 2.4.9c.4-.3.9-.6 1.4-.8l.5-2.5Z";
        stroke: root.icon-color;
        stroke-width: 1.8px;
        fill: transparent;
    }

    Path {
        x: 5px;
        y: 5px;
        width: 24px;
        height: 24px;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: "M15.1 12 A3.1 3.1 0 1 0 8.9 12 A3.1 3.1 0 1 0 15.1 12";
        stroke: root.icon-color;
        stroke-width: 1.8px;
        fill: transparent;
    }
}

export component LegendTooltipBubble inherits Rectangle {
    in property <string> text;
    in property <bool> light;

    width: root.text == "" ? 0px : min(tip-text.preferred-width + 18px, 560px);
    height: root.text == "" ? 0px : 30px;
    border-radius: 7px;
    background: root.light ? #222222 : #f2f2f2;
    border-width: root.text == "" ? 0px : 1px;
    border-color: root.light ? #111111 : #ffffff;

    tip-text := Text {
        x: 9px;
        width: parent.width - 18px;
        height: 100%;
        text: root.text;
        color: root.light ? #ffffff : #202020;
        font-size: 11px;
        font-weight: 600;
        overflow: elide;
        vertical-alignment: center;
    }
}

export component TooltipText inherits Rectangle {
    in property <string> text;
    in property <string> tooltip-text;
    in property <bool> light;
    in property <color> text-color;
    in property <length> text-font-size: 11px;
    in property <int> text-font-weight: 400;

    callback clicked();
    callback pointer-event(PointerEvent);
    callback hover-changed(bool);

    height: display-text.preferred-height;
    background: transparent;

    display-text := Text {
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: root.text-color;
        font-size: root.text-font-size;
        font-weight: root.text-font-weight;
        overflow: elide;
        vertical-alignment: center;
    }

    tooltip-measure := Text {
        width: 0px;
        height: 0px;
        text: root.tooltip-text;
        font-size: 11px;
        font-weight: 600;
        visible: false;
    }

    tooltip-delay := Timer {
        interval: 800ms;
        running: false;

        triggered => {
            self.running = false;
            if tooltip-touch.has-hover && root.tooltip-text != "" {
                tooltip-popup.show();
            }
        }
    }

    tooltip-popup := PopupWindow {
        x: 0px;
        y: root.height + 6px;
        width: root.tooltip-text == "" ? 0px : min(tooltip-measure.preferred-width + 18px, 560px);
        height: root.tooltip-text == "" ? 0px : 30px;
        close-policy: PopupClosePolicy.no-auto-close;

        LegendTooltipBubble {
            width: 100%;
            height: 100%;
            text: root.tooltip-text;
            light: root.light;
        }
    }

    changed tooltip-text => {
        tooltip-delay.running = false;
        tooltip-popup.close();
    }

    tooltip-touch := TouchArea {
        mouse-cursor: pointer;

        clicked => {
            root.clicked();
        }

        pointer-event(event) => {
            root.pointer-event(event);
        }

        changed has-hover => {
            if self.has-hover && root.tooltip-text != "" {
                tooltip-delay.running = true;
            } else {
                tooltip-delay.running = false;
                tooltip-popup.close();
            }
            root.hover-changed(self.has-hover);
        }
    }
}

export component SettingToggle inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in property <bool> light;
    in property <bool> tooltips-enabled;
    in-out property <bool> checked;
    callback toggled();

    height: 58px;
    border-radius: 8px;
    background: root.light ? toggle-touch.has-hover ? #ffffff : #f6f6f6 : toggle-touch.has-hover ? #242424 : #202020;
    border-width: 1px;
    border-color: root.light ? toggle-touch.has-hover ? #bdbdbd : #d4d4d4 : #363636;

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    tooltip-measure := Text {
        width: 0px;
        height: 0px;
        text: root.label + ": " + root.description;
        font-size: 11px;
        font-weight: 600;
        visible: false;
    }

    tooltip-delay := Timer {
        interval: 800ms;
        running: false;

        triggered => {
            self.running = false;
            if toggle-touch.has-hover && root.tooltips-enabled {
                tooltip-popup.show();
            }
        }
    }

    tooltip-popup := PopupWindow {
        x: 0px;
        y: root.height + 6px;
        width: root.tooltips-enabled ? min(tooltip-measure.preferred-width + 18px, 560px) : 0px;
        height: root.tooltips-enabled ? 30px : 0px;
        close-policy: PopupClosePolicy.no-auto-close;

        LegendTooltipBubble {
            width: 100%;
            height: 100%;
            text: root.label + ": " + root.description;
            light: root.light;
        }
    }

    changed tooltips-enabled => {
        if (!root.tooltips-enabled) {
            tooltip-delay.running = false;
            tooltip-popup.close();
        }
    }

    toggle-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }

        changed has-hover => {
            if self.has-hover && root.tooltips-enabled {
                tooltip-delay.running = true;
            } else {
                tooltip-delay.running = false;
                tooltip-popup.close();
            }
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 9px;
        padding-bottom: 9px;
        spacing: 12px;

        Rectangle {
            width: 30px;
            height: 18px;
            border-radius: 9px;
            background: root.light ? root.checked ? #202020 : #e1e1e1 : root.checked ? #d6d6d6 : #303030;
            border-width: 1px;
            border-color: root.light ? root.checked ? #202020 : #a9a9a9 : root.checked ? #eeeeee : #666666;

            Rectangle {
                x: root.checked ? 14px : 2px;
                y: 2px;
                width: 14px;
                height: 14px;
                border-radius: 7px;
                background: root.light ? root.checked ? #ffffff : #777777 : root.checked ? #181818 : #b8b8b8;
            }
        }

        VerticalLayout {
            spacing: 2px;

            Text {
                text: root.label;
                color: root.light ? #1f1f1f : #eeeeee;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }

            Text {
                horizontal-stretch: 1;
                text: root.description;
                color: root.light ? #5f5f5f : #9a9a9a;
                font-size: 11px;
                overflow: elide;
                vertical-alignment: center;
            }
        }
    }
}

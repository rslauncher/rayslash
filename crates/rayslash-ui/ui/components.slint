export component SearchBox inherits Rectangle {
    in-out property <string> query-text;

    callback close-requested();
    callback select-previous();
    callback select-next();
    callback activate-selected(bool);
    callback query-changed(string);
    callback control-modifier-changed(bool);

    height: 62px;
    border-radius: 12px;
    background: search-input.has-focus ? #242424 : #202020;
    border-width: 1.5px;
    border-color: search-input.has-focus ? #7a7a7a : #3a3a3a;

    forward-focus: search-input;

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    Text {
        x: 18px;
        y: 0px;
        height: parent.height;
        vertical-alignment: center;
        text: "Search apps, projects, or calculations";
        color: #9a9a9a;
        font-size: 18px;
        visible: search-input.text == "";
    }

    search-input := TextInput {
        x: 18px;
        y: 0px;
        width: parent.width - 36px;
        height: parent.height;
        vertical-alignment: center;
        color: #f2f2f2;
        font-size: 19px;
        font-weight: 500;
        single-line: true;
        selection-background-color: #d4d4d4;
        selection-foreground-color: #181818;
        text <=> root.query-text;

        edited => {
            root.query-changed(search-input.text);
        }

        key-pressed(event) => {
            root.control-modifier-changed(event.modifiers.control);
            if (event.text == Key.Escape) {
                root.close-requested();
                accept
            } else if (event.text == Key.Tab && event.modifiers.shift) {
                root.select-previous();
                accept
            } else if (event.text == Key.Tab) {
                root.select-next();
                accept
            } else if (event.text == Key.UpArrow) {
                root.select-previous();
                accept
            } else if (event.text == Key.DownArrow) {
                root.select-next();
                accept
            } else if (event.text == Key.Return && event.modifiers.control) {
                root.activate-selected(true);
                accept
            } else if (event.text == Key.Return) {
                root.activate-selected(false);
                accept
            } else {
                reject
            }
        }

        key-released(event) => {
            root.control-modifier-changed(
                event.text == Key.Control || event.text == Key.ControlR ? false : event.modifiers.control
            );
            reject
        }
    }
}

export component SettingsGearIcon inherits Rectangle {
    background: transparent;

    Path {
        x: 5px;
        y: 5px;
        width: 24px;
        height: 24px;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: "M9.6 3.1h4.8l.5 2.5c.5.2 1 .4 1.4.8l2.4-.9 2.4 4.1-1.9 1.6v1.6l1.9 1.6-2.4 4.1-2.4-.9c-.4.3-.9.6-1.4.8l-.5 2.5H9.6l-.5-2.5c-.5-.2-1-.4-1.4-.8l-2.4.9-2.4-4.1 1.9-1.6v-1.6L2.9 9.6l2.4-4.1 2.4.9c.4-.3.9-.6 1.4-.8l.5-2.5Z";
        stroke: #d8d8d8;
        stroke-width: 1.8px;
        fill: transparent;
    }

    Path {
        x: 5px;
        y: 5px;
        width: 24px;
        height: 24px;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: "M15.1 12 A3.1 3.1 0 1 0 8.9 12 A3.1 3.1 0 1 0 15.1 12";
        stroke: #d8d8d8;
        stroke-width: 1.8px;
        fill: transparent;
    }
}

export component SettingToggle inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in-out property <bool> checked;
    callback toggled();

    height: 52px;
    border-radius: 8px;
    background: toggle-touch.has-hover ? #242424 : #202020;
    border-width: 1px;
    border-color: #363636;

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 12px;

        Rectangle {
            width: 30px;
            height: 18px;
            border-radius: 9px;
            background: root.checked ? #d6d6d6 : #303030;
            border-width: 1px;
            border-color: root.checked ? #eeeeee : #666666;

            Rectangle {
                x: root.checked ? 14px : 2px;
                y: 2px;
                width: 14px;
                height: 14px;
                border-radius: 7px;
                background: root.checked ? #181818 : #b8b8b8;
            }
        }

        VerticalLayout {
            spacing: 2px;

            Text {
                text: root.label;
                color: #eeeeee;
                font-size: 13px;
                font-weight: 700;
            }

            Text {
                text: root.description;
                color: #9a9a9a;
                font-size: 10px;
                overflow: elide;
            }
        }
    }

    toggle-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }
}

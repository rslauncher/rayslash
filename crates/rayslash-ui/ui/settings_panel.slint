import { SettingToggle } from "./components.slint";
import { AliasItem, AppChoiceItem, ModuleItem, WebSearchItem } from "./models.slint";
import { ModulesPanel } from "./modules_panel.slint";

component SegmentButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> light;
    callback clicked();

    height: 34px;
    border-radius: 7px;
    background: root.selected ? root.light ? #202020 : #d6d6d6 : segment-touch.has-hover ? root.light ? #eeeeee : #292929 : transparent;

    animate background { duration: 90ms; }

    Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: root.selected ? root.light ? #ffffff : #181818 : root.light ? #333333 : #dddddd;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    segment-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component MiniToggle inherits Rectangle {
    in-out property <bool> checked;
    in property <bool> light;
    callback toggled();
    width: 34px; height: 20px; border-radius: 10px;
    background: root.light ? root.checked ? #202020 : #dedede : root.checked ? #d6d6d6 : #343434;
    border-width: 1px; border-color: root.light ? #999999 : #666666;
    Rectangle { x: root.checked ? 16px : 2px; y: 2px; width: 14px; height: 14px; border-radius: 7px; background: root.light ? root.checked ? #ffffff : #777777 : root.checked ? #181818 : #b8b8b8; }
    TouchArea { mouse-cursor: pointer; clicked => { root.checked = !root.checked; root.toggled(); } }
}

component EngineField inherits Rectangle {
    in-out property <string> value;
    in property <bool> light;
    in property <bool> editable: true;
    in property <string> hint;
    border-radius: 6px; border-width: 1px; border-color: field.has-focus ? (root.light ? #666666 : #888888) : (root.light ? #c8c8c8 : #484848);
    background: root.light ? #ffffff : #191919;
    Text { x: 8px; width: parent.width - 16px; height: parent.height; text: root.hint; visible: root.value == ""; color: root.light ? #888888 : #777777; font-size: 11px; vertical-alignment: center; overflow: elide; }
    field := TextInput { x: 8px; width: parent.width - 16px; height: parent.height; enabled: root.editable; text <=> root.value; color: root.editable ? root.light ? #222222 : #eeeeee : root.light ? #777777 : #888888; font-size: 11px; single-line: true; vertical-alignment: center; }
}

export component SettingsPanel inherits FocusScope {
    in-out property <bool> open;
    in property <[AppChoiceItem]> alternate-opener-choices;
    in property <bool> light;
    in-out property <string> folder-sources;
    in-out property <string> aliases-text;
    in-out property <string> web-searches-text;
    in property <[AliasItem]> aliases;
    in property <[WebSearchItem]> web-searches;
    in property <[ModuleItem]> modules;
    in-out property <string> alternate-folder-opener-command;
    in-out property <bool> provider-apps;
    in-out property <bool> provider-folders;
    in-out property <bool> provider-calculator;
    in-out property <bool> provider-aliases;
    in-out property <bool> provider-web-search;
    in-out property <bool> provider-unit-conversion;
    in-out property <bool> provider-currency-conversion;
    in-out property <bool> provider-time-lookup;
    in-out property <bool> provider-utility-actions;
    in-out property <bool> alternate-folder-opener-enabled;
    in-out property <bool> ranking-learn-from-usage;
    in-out property <string> theme;
    in-out property <string> density;
    in-out property <string> max-results;
    in-out property <bool> show-tooltips;
    in property <string> config-path;
    in property <string> state-path;
    in property <string> socket-path;
    in property <string> project-count;
    in property <string> app-count;
    in property <string> icon-count;
    in property <string> ranking-entry-count;
    in-out property <bool> alternate-picker-open;

    callback cancel-requested();
    callback browse-folder-requested(string);
    callback choose-alternate-opener-requested(string);
    callback clear-ranking-requested();
    callback alias-save-requested(int, string, string, string, string);
    callback alias-add-requested();
    callback alias-remove-requested(int);
    callback web-search-save-requested(int, string, string, string, bool);
    callback web-search-add-requested();
    callback web-search-remove-requested(int);
    callback module-toggle-requested(string, bool);
    callback save-requested(string, string, bool, bool, bool, bool, bool, bool, bool, bool, bool, bool, bool, string, string, string, bool, string, string);

    private property <string> settings-section: "general";

    private property <color> text-strong: root.light ? #1f1f1f : #f2f2f2;
    private property <color> text-main: root.light ? #2d2d2d : #d8d8d8;
    private property <color> text-muted: root.light ? #666666 : #9a9a9a;
    private property <color> text-soft: root.light ? #555555 : #b8b8b8;
    private property <color> field-bg: root.light ? #ffffff : #202020;
    private property <color> field-bg-hover: root.light ? #f0f0f0 : #292929;
    private property <color> field-bg-pressed: root.light ? #e6e6e6 : #333333;
    private property <color> field-border: root.light ? #d0d0d0 : #3a3a3a;
    private property <color> field-border-focus: root.light ? #747474 : #777777;
    private property <color> icon-fill: root.light ? #4a4a4a : #d0d0d0;

    public function focus-settings() {
        settings-scroll.viewport-y = 0px;
        modules-panel.reset-scroll();
        root.focus();
    }

    function save-settings() {
        root.save-requested(
            settings-sources-input.text,
            settings-editor-input.text,
            root.provider-apps,
            root.provider-folders,
            root.provider-calculator,
            root.provider-aliases,
            root.provider-web-search,
            root.provider-unit-conversion,
            root.provider-currency-conversion,
            root.provider-time-lookup,
            root.provider-utility-actions,
            root.alternate-folder-opener-enabled,
            root.ranking-learn-from-usage,
            root.theme,
            root.density,
            settings-max-results-input.text,
            root.show-tooltips,
            root.aliases-text,
            root.web-searches-text);
    }

    min-height: 0px;
    preferred-height: root.open ? 320px : 0px;
    visible: root.open;
    vertical-stretch: root.open ? 1 : 0;
    forward-focus: settings-sources-input;

    changed open => {
        if (root.open) {
            root.settings-section = "general";
            settings-scroll.viewport-y = 0px;
            modules-panel.reset-scroll();
        }
    }

    key-pressed(event) => {
        if (event.text == Key.Escape) {
            root.cancel-requested();
            accept
        } else {
            reject
        }
    }

    Text {
        x: 0px;
        y: 0px;
        width: 100%;
        height: 24px;
        text: "Settings";
        color: root.text-strong;
        font-size: 18px;
        font-weight: 700;
        vertical-alignment: center;
    }

    Rectangle {
        x: 0px;
        y: 30px;
        width: 100%;
        height: 38px;
        border-radius: 9px;
        background: root.light ? #e7e7e7 : #222222;
        border-width: 1px;
        border-color: root.field-border;

        HorizontalLayout {
            padding: 2px;
            spacing: 2px;

            SegmentButton {
                label: "General";
                selected: root.settings-section == "general";
                light: root.light;
                clicked => {
                    root.settings-section = "general";
                    settings-scroll.viewport-y = 0px;
                }
            }

            SegmentButton {
                label: "Modules";
                selected: root.settings-section == "modules";
                light: root.light;
                clicked => {
                    root.settings-section = "modules";
                    modules-panel.reset-scroll();
                }
            }
        }
    }

    settings-scroll := Flickable {
        y: 76px;
        width: 100%;
        height: parent.height - 76px;
        visible: root.settings-section == "general";
        viewport-width: self.width;
        viewport-height: root.open ? (root.alternate-picker-open ? 1139px : 989px) + root.aliases.length * 134px + root.web-searches.length * 134px : 0px;
        interactive: root.open && root.settings-section == "general";

        VerticalLayout {
            width: settings-scroll.width;
            spacing: 9px;

            Text {
                text: "Folder source";
                color: root.text-main;
                font-size: 12px;
                font-weight: 700;
            }

            HorizontalLayout {
                height: 42px;
                spacing: 8px;

                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 8px;
                    background: root.field-bg;
                    border-width: 1px;
                    border-color: settings-sources-input.has-focus ? root.field-border-focus : root.field-border;

                    settings-sources-input := TextInput {
                        x: 12px;
                        y: 0px;
                        width: parent.width - 24px;
                        height: parent.height;
                        text: root.folder-sources;
                        color: root.text-strong;
                        font-size: 13px;
                        single-line: true;
                        vertical-alignment: center;

                        key-pressed(event) => {
                            if (event.text == Key.Return) {
                                root.save-settings();
                                accept
                            } else if (event.text == Key.Escape) {
                                root.cancel-requested();
                                accept
                            } else {
                                reject
                            }
                        }

                        changed has-focus => {
                            if (!self.has-focus) {
                                root.save-settings();
                            }
                        }
                    }
                }

                Rectangle {
                    width: 42px;
                    border-radius: 8px;
                    background: browse-touch.pressed ? root.field-bg-pressed : browse-touch.has-hover ? root.field-bg-hover : root.field-bg;
                    border-width: 1px;
                    border-color: root.field-border;

                    Rectangle {
                        x: 9px;
                        y: 18px;
                        width: 24px;
                        height: 14px;
                        border-radius: 3px;
                        background: root.icon-fill;
                    }

                    Rectangle {
                        x: 10px;
                        y: 13px;
                        width: 12px;
                        height: 7px;
                        border-radius: 2px;
                        background: root.icon-fill;
                    }

                    browse-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.browse-folder-requested(settings-sources-input.text);
                        }
                    }
                }
            }

            Text {
                text: "Immediate child folders become folder results; separate multiple sources with semicolons";
                color: root.text-muted;
                font-size: 11px;
            }

            Text {
                text: "Alternate folder opener";
                color: root.text-main;
                font-size: 12px;
                font-weight: 700;
            }

            HorizontalLayout {
                height: 42px;
                spacing: 8px;

                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 8px;
                    background: root.field-bg;
                    border-width: 1px;
                    border-color: settings-editor-input.has-focus ? root.field-border-focus : root.field-border;

                    settings-editor-input := TextInput {
                        x: 12px;
                        y: 0px;
                        width: parent.width - 24px;
                        height: parent.height;
                        text: root.alternate-folder-opener-command;
                        color: root.text-strong;
                        font-size: 13px;
                        single-line: true;
                        vertical-alignment: center;

                        key-pressed(event) => {
                            if (event.text == Key.Return) {
                                root.save-settings();
                                accept
                            } else if (event.text == Key.Escape) {
                                root.cancel-requested();
                                accept
                            } else {
                                reject
                            }
                        }

                        changed has-focus => {
                            if (!self.has-focus) {
                                root.save-settings();
                            }
                        }
                    }
                }

                Rectangle {
                    width: 82px;
                    height: 42px;
                    border-radius: 8px;
                    background: picker-touch.pressed ? root.field-bg-pressed : picker-touch.has-hover || root.alternate-picker-open ? root.field-bg-hover : root.field-bg;
                    border-width: 1px;
                    border-color: root.field-border;

                    Text {
                        width: 100%;
                        height: 100%;
                        text: "Pick";
                        color: root.text-main;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    picker-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.alternate-picker-open = !root.alternate-picker-open;
                        }
                    }
                }
            }

            if root.alternate-picker-open: Flickable {
                height: 154px;
                viewport-width: self.width;
                viewport-height: root.alternate-opener-choices.length * 38px;
                interactive: true;

                VerticalLayout {
                    width: parent.width;
                    spacing: 4px;

                    for choice in root.alternate-opener-choices: Rectangle {
                        height: 34px;
                        border-radius: 8px;
                        background: choice-touch.pressed ? root.field-bg-pressed : choice-touch.has-hover ? root.field-bg-hover : root.field-bg;
                        border-width: 1px;
                        border-color: root.field-border;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            padding-top: 5px;
                            padding-bottom: 5px;
                            spacing: 8px;

                            Rectangle {
                                width: 22px;
                                height: 22px;
                                background: transparent;

                                Image {
                                    width: 22px;
                                    height: 22px;
                                    source: choice.icon;
                                    image-fit: contain;
                                    visible: choice.has_icon;
                                }

                                Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    border-radius: 5px;
                                    background: root.light ? #dfdfdf : #3a3a3a;
                                    visible: !choice.has_icon;

                                    Text {
                                        width: 100%;
                                        height: 100%;
                                        text: "AP";
                                        color: root.text-muted;
                                        font-size: 9px;
                                        font-weight: 800;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Text {
                                text: choice.name;
                                color: root.text-strong;
                                font-size: 12px;
                                font-weight: 700;
                                horizontal-stretch: 1;
                                overflow: elide;
                                vertical-alignment: center;
                            }

                            Text {
                                text: choice.command;
                                color: root.text-muted;
                                font-size: 10px;
                                horizontal-stretch: 0;
                                overflow: elide;
                                vertical-alignment: center;
                            }
                        }

                        choice-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.alternate-folder-opener-command = choice.command;
                                root.alternate-picker-open = false;
                                root.choose-alternate-opener-requested(choice.command);
                                root.save-settings();
                            }
                        }
                    }
                }
            }

            Text {
                text: "Used with Ctrl+Enter or Ctrl+click instead of the system file manager";
                color: root.text-muted;
                font-size: 11px;
            }

            Text {
                text: "Aliases";
                color: root.text-main;
                font-size: 12px;
                font-weight: 700;
            }

            Rectangle { height: 34px; border-radius: 8px; background: alias-add.pressed ? root.field-bg-pressed : alias-add.has-hover ? root.field-bg-hover : root.field-bg;
                Text { text: "+  Add alias"; color: root.text-main; font-size: 12px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                alias-add := TouchArea { mouse-cursor: pointer; clicked => { root.alias-add-requested(); } }
            }

            for alias[index] in root.aliases: Rectangle {
                height: 126px; border-radius: 10px; background: root.field-bg; border-width: 1px; border-color: root.field-border;
                VerticalLayout { padding: 8px; spacing: 6px;
                    HorizontalLayout { height: 34px; spacing: 9px;
                        Rectangle { width: 34px; border-radius: 8px; background: root.field-bg-hover;
                            Path { x: 8px; y: 8px; width: 18px; height: 18px; viewbox-width: 24; viewbox-height: 24; stroke: root.icon-fill; stroke-width: 2px; fill: transparent; commands: "M10 13a5 5 0 0 0 7.1.1l3-3a5 5 0 0 0-7.1-7.1l-1.7 1.7 M14 11a5 5 0 0 0-7.1-.1l-3 3a5 5 0 0 0 7.1 7.1l1.7-1.7"; }
                        }
                        VerticalLayout { spacing: 1px; Text { text: alias.name; color: root.text-strong; font-size: 14px; font-weight: 700; overflow: elide; } Text { text: alias.keyword; color: root.text-muted; font-size: 10px; overflow: elide; } }
                    }
                    HorizontalLayout { height: 26px; spacing: 6px;
                        EngineField { value <=> alias.name; light: root.light; hint: "Alias name"; }
                        EngineField { width: 145px; value <=> alias.keyword; light: root.light; hint: "Keyword"; }
                    }
                    HorizontalLayout { height: 26px; spacing: 6px;
                        EngineField { width: 112px; value <=> alias.kind; light: root.light; hint: "Kind"; }
                        EngineField { value <=> alias.target; light: root.light; hint: "Target URL, path, or command"; }
                        Rectangle { width: 28px; border-radius: 6px; background: save-alias.pressed ? root.field-bg-pressed : save-alias.has-hover ? root.field-bg-hover : transparent; Text { text: "✓"; color: root.text-main; font-size: 15px; horizontal-alignment: center; vertical-alignment: center; } save-alias := TouchArea { mouse-cursor: pointer; clicked => { root.alias-save-requested(index, alias.name, alias.keyword, alias.kind, alias.target); } } }
                        Rectangle { width: 28px; border-radius: 6px; background: remove-alias.pressed ? #6f2020 : remove-alias.has-hover ? #4c2424 : transparent;
                            Path { x: 6px; y: 5px; width: 16px; height: 16px; viewbox-width: 24; viewbox-height: 24; stroke: #ef7777; stroke-width: 2px; fill: transparent; commands: "M3 6h18 M8 6V4h8v2 M19 6l-1 14H6L5 6 M10 10v6 M14 10v6"; }
                            remove-alias := TouchArea { mouse-cursor: pointer; clicked => { root.alias-remove-requested(index); } }
                        }
                    }
                }
            }

            Text {
                text: "Search engines";
                color: root.text-main;
                font-size: 12px;
                font-weight: 700;
            }

            Rectangle { height: 34px; border-radius: 8px; background: search-add.pressed ? root.field-bg-pressed : search-add.has-hover ? root.field-bg-hover : root.field-bg;
                Text { text: "+  Add search engine"; color: root.text-main; font-size: 12px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                search-add := TouchArea { mouse-cursor: pointer; clicked => { root.web-search-add-requested(); } }
            }

            for engine[index] in root.web-searches: Rectangle {
                height: 126px; border-radius: 10px; background: root.field-bg; border-width: 1px; border-color: root.field-border;
                VerticalLayout { padding: 8px; spacing: 6px;
                    HorizontalLayout { height: 34px; spacing: 9px;
                        Rectangle { width: 34px; border-radius: 8px; background: root.field-bg-hover;
                            Path { x: 8px; y: 7px; width: 18px; height: 18px; viewbox-width: 24; viewbox-height: 24; stroke: root.icon-fill; stroke-width: 2px; fill: transparent; commands: "M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M16.2 16.2 L21 21"; }
                        }
                        VerticalLayout { spacing: 1px; Text { text: engine.name == "" ? "New search engine" : engine.name; color: root.text-strong; font-size: 14px; font-weight: 700; overflow: elide; } Text { text: engine.keyword == "" ? "Choose a keyword" : engine.keyword; color: root.text-muted; font-size: 10px; overflow: elide; } }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        Rectangle { width: 34px; background: transparent; MiniToggle { y: 7px; checked: engine.enabled; light: root.light; toggled => { root.web-search-save-requested(index, engine.name, engine.keyword, engine.url, self.checked); } } }
                    }
                    HorizontalLayout { height: 26px; spacing: 6px;
                        EngineField { value <=> engine.name; light: root.light; editable: index != 0; hint: "Search engine name"; }
                        EngineField { width: 145px; value <=> engine.keyword; light: root.light; editable: index != 0; hint: "Keyword"; }
                    }
                    HorizontalLayout { height: 26px; spacing: 6px;
                        EngineField { value <=> engine.url; light: root.light; hint: "URL with %s in place of the search term"; }
                        Rectangle { width: 28px; border-radius: 6px; background: save-engine.pressed ? root.field-bg-pressed : save-engine.has-hover ? root.field-bg-hover : transparent; Text { text: "✓"; color: root.text-main; font-size: 15px; horizontal-alignment: center; vertical-alignment: center; } save-engine := TouchArea { mouse-cursor: pointer; clicked => { root.web-search-save-requested(index, engine.name, engine.keyword, engine.url, engine.enabled); } } }
                        Rectangle { width: index == 0 ? 0px : 28px; visible: index != 0; border-radius: 6px; background: remove-engine.pressed ? #6f2020 : remove-engine.has-hover ? #4c2424 : transparent;
                            Path { x: 6px; y: 5px; width: 16px; height: 16px; viewbox-width: 24; viewbox-height: 24; stroke: #ef7777; stroke-width: 2px; fill: transparent; commands: "M3 6h18 M8 6V4h8v2 M19 6l-1 14H6L5 6 M10 10v6 M14 10v6"; }
                            remove-engine := TouchArea { mouse-cursor: pointer; clicked => { root.web-search-remove-requested(index); } }
                        }
                    }
                }
            }

            Text {
                text: "Search features";
                color: root.text-main;
                font-size: 12px;
                font-weight: 700;
            }

            HorizontalLayout {
                height: 58px;
                spacing: 8px;

                SettingToggle {
                    label: "Apps";
                    description: "Desktop applications";
                    light: root.light;
                    tooltips-enabled: root.show-tooltips;
                    checked <=> root.provider-apps;
                    toggled => {
                        root.save-settings();
                    }
                }

                SettingToggle {
                    label: "Folders";
                    description: "Folder source results";
                    light: root.light;
                    tooltips-enabled: root.show-tooltips;
                    checked <=> root.provider-folders;
                    toggled => {
                        root.save-settings();
                    }
                }
            }

            HorizontalLayout {
                height: 58px;
                spacing: 8px;

                SettingToggle {
                    label: "Learning";
                    description: "Local result ranking";
                    light: root.light;
                    tooltips-enabled: root.show-tooltips;
                    checked <=> root.ranking-learn-from-usage;
                    toggled => {
                        root.save-settings();
                    }
                }

                Rectangle {
                    width: 146px;
                    height: 58px;
                    border-radius: 8px;
                    background: clear-ranking-touch.pressed ? root.field-bg-pressed : clear-ranking-touch.has-hover ? root.field-bg-hover : root.field-bg;
                    border-width: 1px;
                    border-color: root.field-border;

                    VerticalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 2px;

                        Text {
                            text: "Clear history";
                            color: root.text-main;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.ranking-entry-count + " entries";
                            color: root.text-muted;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                    }

                    clear-ranking-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.clear-ranking-requested();
                        }
                    }
                }
            }

            HorizontalLayout {
                height: 58px;
                spacing: 8px;

                SettingToggle {
                    label: "Alt opener";
                    description: "Ctrl+Enter folders";
                    light: root.light;
                    tooltips-enabled: root.show-tooltips;
                    checked <=> root.alternate-folder-opener-enabled;
                    toggled => {
                        root.save-settings();
                    }
                }

                SettingToggle {
                    label: "Tooltips";
                    description: "Delayed detail popups";
                    light: root.light;
                    tooltips-enabled: root.show-tooltips;
                    checked <=> root.show-tooltips;
                    toggled => {
                        root.save-settings();
                    }
                }
            }

            HorizontalLayout {
                height: 42px;
                spacing: 8px;

                VerticalLayout {
                    spacing: 4px;

                    Text {
                        text: "Max results";
                        color: root.text-main;
                        font-size: 12px;
                        font-weight: 700;
                    }

                    Rectangle {
                        height: 26px;
                        border-radius: 7px;
                        background: root.field-bg;
                        border-width: 1px;
                        border-color: settings-max-results-input.has-focus ? root.field-border-focus : root.field-border;

                        settings-max-results-input := TextInput {
                            x: 10px;
                            y: 0px;
                            width: parent.width - 20px;
                            height: parent.height;
                            text: root.max-results;
                            color: root.text-strong;
                            font-size: 12px;
                            single-line: true;
                            vertical-alignment: center;

                            key-pressed(event) => {
                                if (event.text == Key.Return) {
                                    root.save-settings();
                                    accept
                                } else if (event.text == Key.Escape) {
                                    root.cancel-requested();
                                    accept
                                } else {
                                    reject
                                }
                            }

                            changed has-focus => {
                                if (!self.has-focus) {
                                    root.save-settings();
                                }
                            }
                        }
                    }
                }
            }

            Text {
                text: "Appearance";
                color: root.text-main;
                font-size: 12px;
                font-weight: 700;
            }

            HorizontalLayout {
                height: 80px;
                spacing: 8px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 72px;
                    border-radius: 8px;
                    background: root.field-bg;
                    border-width: 1px;
                    border-color: root.field-border;

                    VerticalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-top: 7px;
                        padding-bottom: 7px;
                        spacing: 6px;

                        Text {
                            text: "Theme";
                            color: root.text-muted;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        HorizontalLayout {
                            spacing: 0px;

                            SegmentButton {
                                label: "Dark";
                                selected: root.theme == "dark";
                                light: root.light;
                                clicked => {
                                    root.theme = "dark";
                                    root.save-settings();
                                }
                            }

                            SegmentButton {
                                label: "Dim";
                                selected: root.theme == "dim";
                                light: root.light;
                                clicked => {
                                    root.theme = "dim";
                                    root.save-settings();
                                }
                            }

                            SegmentButton {
                                label: "Light";
                                selected: root.theme == "light";
                                light: root.light;
                                clicked => {
                                    root.theme = "light";
                                    root.save-settings();
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: 238px;
                    height: 72px;
                    border-radius: 8px;
                    background: root.field-bg;
                    border-width: 1px;
                    border-color: root.field-border;

                    VerticalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-top: 7px;
                        padding-bottom: 7px;
                        spacing: 6px;

                        Text {
                            text: "Density";
                            color: root.text-muted;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        HorizontalLayout {
                            spacing: 0px;

                            SegmentButton {
                                label: "Comfort";
                                selected: root.density == "comfortable";
                                light: root.light;
                                clicked => {
                                    root.density = "comfortable";
                                    root.save-settings();
                                }
                            }

                            SegmentButton {
                                label: "Compact";
                                selected: root.density == "compact";
                                light: root.light;
                                clicked => {
                                    root.density = "compact";
                                    root.save-settings();
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 8px;
                background: transparent;
            }

            HorizontalLayout {
                height: 54px;
                spacing: 12px;

                VerticalLayout {
                    spacing: 2px;

                    Text {
                        text: "Config location";
                        color: root.text-main;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Text {
                        text: root.config-path;
                        color: root.text-muted;
                        font-size: 10px;
                        overflow: elide;
                    }
                }

                VerticalLayout {
                    spacing: 2px;

                    Text {
                        text: "State location";
                        color: root.text-main;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Text {
                        text: root.state-path;
                        color: root.text-muted;
                        font-size: 10px;
                        overflow: elide;
                    }
                }
            }

            HorizontalLayout {
                height: 18px;
                spacing: 14px;

                Text {
                    text: "Folders: " + root.project-count;
                    color: root.text-soft;
                    font-size: 11px;
                    horizontal-stretch: 0;
                }

                Text {
                    text: "Apps: " + root.app-count;
                    color: root.text-soft;
                    font-size: 11px;
                    horizontal-stretch: 0;
                }

                Text {
                    text: "Icons: " + root.icon-count;
                    color: root.text-soft;
                    font-size: 11px;
                    horizontal-stretch: 0;
                }

                Text {
                    text: "Socket: " + root.socket-path;
                    color: root.text-muted;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            Rectangle {
                height: 8px;
                background: transparent;
            }
        }
    }

    modules-panel := ModulesPanel {
        y: 76px;
        width: 100%;
        height: parent.height - 76px;
        visible: root.settings-section == "modules";
        modules: root.modules;
        light: root.light;

        module-toggle-requested(id, enabled) => {
            root.module-toggle-requested(id, enabled);
        }
    }
}
